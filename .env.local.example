# Gemini is now called via Vertex AI using a service-account credential,
# instead of a plain Gemini Developer API key. The "AQ."-format keys issued
# to this Google account currently hit a Google-side bug where the free tier
# is either locked at limit:0 or rejected outright with a 401
# ACCESS_TOKEN_TYPE_UNSUPPORTED error. Vertex AI auth uses a real
# service-account credential (OAuth2 under the hood), which sidesteps that
# bug entirely.
GCP_PROJECT_ID=fast-cascade-443712-b5
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=Users/Loretta/Documents/GitHub/EcoVest/gcp-service-account.json
GEMINI_MODEL=gemini-2.5-flash

# Signs session JWTs — generated with `openssl rand -base64 32`.
AUTH_SECRET=UL7LX2iTPk1VPN2tgHX4i7i1hMvQeNaRNakEYKWOBbI=
