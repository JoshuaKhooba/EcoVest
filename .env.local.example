# --- Supabase (user accounts, positions, transaction history) -------------
# Create a free project at https://supabase.com, then run supabase/schema.sql
# once in that project's SQL Editor. Find these values under
# Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key
# Secret — server-only, never exposed to the browser. Bypasses Row Level
# Security, which is why the tables in schema.sql have no public policies.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini (via Vertex AI) -------------------------------------------------
# Vertex AI mode instead of a plain Gemini Developer API key (see README for
# why). Fill these in with your own project's values.
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Pick ONE of the next two, depending on where you're running the app:
#
# On Vercel (or any host without a persistent filesystem) — paste the ENTIRE
# contents of your downloaded service-account JSON key as one env var:
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", ...}
#
# For local dev only (`npm run dev`) — an absolute path to that same file on
# your machine works too, and takes priority if GCP_SERVICE_ACCOUNT_KEY isn't set:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/gcp-service-account.json

# --- Email (forgot-password reset links) -----------------------------------
# Free account at https://resend.com -> API Keys -> Create API Key.
# Without this set, the forgot-password form returns a clear error instead of
# silently failing; everything else in the app works fine without it.
RESEND_API_KEY=your-resend-api-key
# Optional — defaults to Resend's shared onboarding@resend.dev sender, which
# works without owning a domain but may be sandboxed to your own verified
# email until you verify a domain in the Resend dashboard. Set this once you
# verify your own domain, e.g. "EcoVest <noreply@yourdomain.com>".
# RESEND_FROM_EMAIL=EcoVest <onboarding@resend.dev>

# --- Sessions ---------------------------------------------------------------
# Any long random string — used to sign session JWTs. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=change_this_to_a_long_random_string
